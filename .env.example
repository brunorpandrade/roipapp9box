# Banco de dados (MySQL 8 do docker-compose.yml)
DATABASE_URL=mysql://root:roip_local_root@127.0.0.1:3306/roip

# Base de validação efêmera (S007) — criada/destruída por verify-migration.mjs
DATABASE_URL_VALIDATE=mysql://root:roip_local_root@127.0.0.1:3306/roip_validate

# Base de teste efêmera (S007 estendido ao passo 9) — criada/destruída pelo setup do vitest
DATABASE_URL_TEST=mysql://root:roip_local_root@127.0.0.1:3306/roip_test

# Senha do root do MySQL local (usada pelo docker compose)
MYSQL_ROOT_PASSWORD=roip_local_root

# Seed do Super Admin (nunca versionar o valor real)
SEED_SUPER_ADMIN_PASSWORD=

# Segredo HS256 dos JWTs da plataforma (ME-020, DOC 02 §5).
# Unico — nao ha refresh token no canonico. Nunca versionar o valor real.
JWT_SECRET=

# IA
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
