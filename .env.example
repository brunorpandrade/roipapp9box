# Banco de dados (MySQL 8 do docker-compose.yml)
DATABASE_URL=mysql://root:roip_local_root@127.0.0.1:3306/roip

# Senha do root do MySQL local (usada pelo docker compose)
MYSQL_ROOT_PASSWORD=roip_local_root

# Seed do Super Admin (nunca versionar o valor real)
SEED_SUPER_ADMIN_PASSWORD=

# IA
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
